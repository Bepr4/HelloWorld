MODULE1_LLM_PROVIDER=openai
MODULE1_LLM_MODEL=<your_model>
MODULE1_LLM_BASE_URL=https://api.openai.com
MODULE1_LLM_WIRE_API=chat_completions
MODULE1_MODEL_REASONING_EFFORT=
MODULE1_DISABLE_RESPONSE_STORAGE=false
MODULE1_REQUIRES_OPENAI_AUTH=true
MODULE1_REQUIRES_ANTHROPIC_AUTH=true
MODULE1_ANTHROPIC_AUTH_SCHEME=bearer
MODULE1_LLM_MAX_TOKENS=2048
MODULE1_CONFIG_PATH=
OPENAI_API_KEY=
MODULE1_LLM_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
ANTHROPIC_REASONING_MODEL=
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_DEFAULT_HAIKU_MODEL=
ANTHROPIC_DEFAULT_OPUS_MODEL=
ANTHROPIC_VERSION=2023-06-01

MODULE1_SEARCH_PROVIDER=web_search
MODULE1_SEARCH_API_KEY=
MODULE1_NEWS_FEEDS_PATH=configs/module1/news_feeds.yaml
MODULE1_SEARCH_RESULTS_PER_QUERY=10
MODULE1_TAVILY_SEARCH_ENDPOINT=https://api.tavily.com/search
MODULE1_BRAVE_SEARCH_ENDPOINT=https://api.search.brave.com/res/v1/web/search
MODULE1_NEWS_AGENT_MODE=llm_tools
MODULE1_NEWS_AGENT_MAX_STEPS=6
MODULE1_NEWS_AGENT_MAX_TOOL_CALLS=5

MODULE1_STORAGE_ROOT=data/module1
MODULE1_USER_AGENT=HelloWorldModule1/0.1
MODULE1_HTTP_TIMEOUT_SECONDS=20
MODULE1_CRAWL4AI_ENABLE_BM25=true
MODULE1_CRAWL4AI_BM25_THRESHOLD=1.0
MODULE1_CRAWL4AI_BM25_LANGUAGE=english
